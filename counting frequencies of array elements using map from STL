#include<bits/stdc++.h>
using namespace std;
int main(){
  int n;
  cin>>n;
  int arr[n];
  for(int i=0;i<n;i++){
      cin >> arr[i];
  }
  //pre-compute
  map<int,int> hash;
  for(auto i : arr)
    hash[i]+=1;
  int q;
  cin>>q;
  while(q--){
    int x;
    cin>>x;
    cout << hash[x] << endl;
  }
  return 0;
}
